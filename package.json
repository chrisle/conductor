{
  "name": "conductor",
  "version": "0.1.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev-web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prepare-tmux": "bash scripts/prepare-tmux.sh",
    "package": "bash scripts/package.sh",
    "package:ci": "electron-builder",
    "typecheck": "tsc --build --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:real": "npx playwright test --config playwright.real.config.ts"
  },
  "dependencies": {
    "@jvmr/pptx-to-html": "^1.0.1",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.5",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.iamchrisle.conductor",
    "productName": "Conductor",
    "icon": "build/icon.icns",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "conductor",
        "name": "Conductor Project",
        "role": "Editor",
        "mimeType": "application/x-conductor-project"
      }
    ],
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extraResources": [
        { "from": "conductord/conductord", "to": "conductord" }
      ]
    },
    "win": {
      "target": "nsis",
      "fileAssociations": [
        {
          "ext": "conductor",
          "name": "Conductor Project"
        }
      ],
      "extraResources": [
        { "from": "conductord/conductord.exe", "to": "conductord.exe" }
      ]
    }
  }
}
