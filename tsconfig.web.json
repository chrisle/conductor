{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@conductor/extension-sdk": ["../conductor-extension-sdk/src/index.ts"],
      "@np3/jira": ["../np3-jira/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../np3-jira/src/**/*",
    "../conductor-extension-sdk/src/**/*"
  ]
}
